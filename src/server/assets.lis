import "go:encoding/base64"

/// Static web UI assets, embedded as base64. Lisette has no //go:embed, so the
/// three files under go-version/web/static/ are baked in verbatim as base64
/// constants and decoded on demand. `asset_for` maps a request path to its
/// decoded bytes and Content-Type. The constants are generated from the source
/// files (base64, line-wrapped); `base64.StdEncoding.DecodeString` ignores the
/// embedded newlines. Do not hand-edit the constants — regenerate them from
/// go-version/web/static/ if the assets change.

const INDEX_HTML_B64 = "
"

const APP_JS_B64 = "
"

const STYLE_CSS_B64 = "
"


/// A named static asset: its decoded bytes and the Content-Type to serve.
pub struct Asset {
  pub body: Slice<byte>,
  pub content_type: string,
}

fn decode(b64: string) -> Slice<byte> {
  match base64.StdEncoding.DecodeString(b64) {
    Partial.Ok(bytes) => bytes,
    Partial.Both(bytes, _) => bytes,
    Partial.Err(_) => [],
  }
}

/// Look up a static asset by request path. `"/"` maps to index.html; returns
/// `None` for unknown paths.
pub fn asset_for(path: string) -> Option<Asset> {
  match path {
    "/" => Some(Asset {
      body: decode(INDEX_HTML_B64),
      content_type: "text/html; charset=utf-8",
    }),
    "/app.js" => Some(Asset {
      body: decode(APP_JS_B64),
      content_type: "application/javascript",
    }),
    "/style.css" => Some(Asset {
      body: decode(STYLE_CSS_B64),
      content_type: "text/css",
    }),
    _ => None,
  }
}
