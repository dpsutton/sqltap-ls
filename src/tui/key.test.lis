/// Decode a string of raw bytes as if read from stdin.
fn decode_str(s: string) -> Slice<Key> {
  decode(s.bytes())
}

fn decode_bytes(bytes: Slice<byte>) -> Slice<Key> {
  decode(bytes)
}

#[test("printable chars decode to Char")]
fn test_chars() {
  let keys = decode_str("qj")
  assert keys.length() == 2
  let assert Key.Char('q') = keys[0]
  let assert Key.Char('j') = keys[1]
}

#[test("arrow escape sequences")]
fn test_arrows() {
  let up = decode_bytes([0x1b, 0x5b, 0x41])
  assert up.length() == 1
  let assert Key.Up = up[0]

  let down = decode_bytes([0x1b, 0x5b, 0x42])
  let assert Key.Down = down[0]

  let right = decode_bytes([0x1b, 0x5b, 0x43])
  let assert Key.Right = right[0]

  let left = decode_bytes([0x1b, 0x5b, 0x44])
  let assert Key.Left = left[0]
}

#[test("pgup/pgdown numbered escapes")]
fn test_paging() {
  let pgup = decode_bytes([0x1b, 0x5b, 0x35, 0x7e]) // ESC [ 5 ~
  let assert Key.PgUp = pgup[0]
  let pgdn = decode_bytes([0x1b, 0x5b, 0x36, 0x7e]) // ESC [ 6 ~
  let assert Key.PgDown = pgdn[0]
}

#[test("lone ESC is Esc, not a garbled sequence")]
fn test_lone_esc() {
  let keys = decode_bytes([0x1b])
  assert keys.length() == 1
  let assert Key.Esc = keys[0]
}

#[test("ctrl chords")]
fn test_ctrl() {
  let assert Key.CtrlC = decode_bytes([0x03])[0]
  let assert Key.CtrlD = decode_bytes([0x04])[0]
  let assert Key.CtrlU = decode_bytes([0x15])[0]
  let assert Key.CtrlL = decode_bytes([0x0c])[0]
}

#[test("enter, space, backspace, tab")]
fn test_named() {
  let assert Key.Enter = decode_bytes([0x0d])[0]
  let assert Key.Enter = decode_bytes([0x0a])[0]
  let assert Key.Space = decode_bytes([0x20])[0]
  let assert Key.Backspace = decode_bytes([0x7f])[0]
  let assert Key.Tab = decode_bytes([0x09])[0]
}

#[test("a full buffer of arrow then char decodes in order")]
fn test_mixed_buffer() {
  // ESC [ B  then 'k' — a real terminal can batch these into one read().
  let keys = decode_bytes([0x1b, 0x5b, 0x42, 0x6b])
  assert keys.length() == 2
  let assert Key.Down = keys[0]
  let assert Key.Char('k') = keys[1]
}

#[test("truncated CSI is dropped, not leaked as garbage")]
fn test_truncated_csi() {
  // ESC [  with no final byte: the Go version leaked "[" here.
  let keys = decode_bytes([0x1b, 0x5b])
  assert keys.is_empty()
}

#[test("multibyte utf-8 rune decodes to one Char")]
fn test_utf8() {
  // 'é' = 0xc3 0xa9
  let keys = decode_bytes([0xc3, 0xa9])
  assert keys.length() == 1
  let assert Key.Char('é') = keys[0]
}
