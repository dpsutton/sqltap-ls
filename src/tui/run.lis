import "go:context"
import "go:os"
import "go:os/signal"
import "go:syscall"
import "go:strings"
import "go:fmt"
import "client"

/// Live entry point for `sqltap watch <addr>`. Sets up a signal-cancelled
/// context, opens the daemon SSE stream, and runs the Bubble Tea program on the
/// alternate screen. A connection failure prints a friendly message and returns
/// without entering the alternate screen (nothing to restore). The Bubble Tea
/// program itself is built and driven in tea_shim.lis (`run`), the only file
/// that touches the bubbletea package.
#[allow(lost_cancel)]
pub fn watch(addr: string) -> Result<(), error> {
  let (ctx, _) = signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)

  let events = match client.watch(ctx, addr) {
    Ok(ch) => ch,
    Err(e) => {
      fmt.Fprintln(os.Stderr, friendly_error(e))
      return Ok(())
    },
  }

  run(ctx, addr, events)
}

/// Turn a connection error into a helpful message, mirroring Go's friendlyError.
pub fn friendly_error(e: error) -> string {
  let msg = f"{e}"
  if strings.Contains(msg, "connection refused") || strings.Contains(msg, "Unavailable") {
    f"Could not connect to sql-tapd.\nIs sql-tapd running?\n\nError: {msg}"
  } else {
    f"Error: {msg}"
  }
}

// --- editor helpers (used by tea_shim's editor_cmd) ------------------------

/// The comment header prepended to the temp .sql file the editor opens.
pub fn editor_header(kind: ExplainKind) -> string {
  let title = kind.title()
  f"-- Edit this query, then save and quit to run {title}.\n-- To cancel, clear the file or quit without saving.\n-- Lines starting with -- are stripped before execution.\n\n"
}

/// $EDITOR, falling back to vi.
pub fn editor_command() -> string {
  let e = os.Getenv("EDITOR")
  if e == "" { "vi" } else { e }
}

/// Strip SQL single-line comments (-- ...) and surrounding whitespace.
pub fn strip_comments(s: string) -> string {
  let mut out: Slice<string> = []
  for line in strings.Split(s, "\n") {
    let trimmed = strings.TrimSpace(line)
    if trimmed == "" || strings.HasPrefix(trimmed, "--") {
      // skip
    } else {
      out = out.append(line)
    }
  }
  strings.TrimSpace(strings.Join(out, "\n"))
}
