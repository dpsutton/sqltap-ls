import "go:os"
import "go:fmt"
import "go:strings"
import "go:golang.org/x/term"

// ANSI control sequences for full-screen raw-terminal rendering.
const ALT_SCREEN_ENTER = "\x1b[?1049h"
const ALT_SCREEN_LEAVE = "\x1b[?1049l"
const CURSOR_HIDE = "\x1b[?25l"
const CURSOR_SHOW = "\x1b[?25h"
const CLEAR_HOME = "\x1b[H\x1b[2J"
// Cursor home (no erase), erase-to-end-of-line, and erase-below. The steady-
// state paint homes then clears each line as it overwrites it and clears any
// rows below the (possibly shorter) new frame — no full-screen erase, so no
// per-frame flicker, and shrinking frames leave no stale rows behind.
const CURSOR_HOME = "\x1b[H"
const ERASE_LINE = "\x1b[K"
const ERASE_BELOW = "\x1b[J"

/// The size of the terminal in character cells.
pub struct Size {
  pub width: int,
  pub height: int,
}

/// A terminal handle: raw-mode lifecycle plus a frame writer. Kept behind a
/// tiny abstraction so the actor loop and tests never touch os.Stdin/Stdout
/// directly — a headless render just calls `frame_string` on a Model instead.
pub struct Terminal {
  fd: int,
  saved: Ref<term.State>,
}

impl Terminal {
  /// Put stdin into raw mode and switch to the alternate screen, hiding the
  /// cursor. Returns the handle whose `restore` undoes all of it. The caller
  /// is responsible for `defer`-ing `restore` (see run.lis).
  pub fn enter() -> Result<Terminal, error> {
    let fd = os.Stdin.Fd() as int
    let saved = term.MakeRaw(fd)?
    write_raw(f"{ALT_SCREEN_ENTER}{CURSOR_HIDE}{CLEAR_HOME}")
    Ok(Terminal { fd, saved })
  }

  /// Leave the alternate screen, show the cursor, and restore the saved
  /// termios. Safe to call once on every exit path (clean quit and ctrl+c).
  pub fn restore(self) {
    write_raw(f"{CURSOR_SHOW}{ALT_SCREEN_LEAVE}")
    let _ = term.Restore(self.fd, self.saved)
  }

  /// Current terminal dimensions. Falls back to a sane 80x24 if the ioctl
  /// fails (e.g. output redirected), so the renderer always has a size.
  pub fn size(self) -> Size {
    match term.GetSize(self.fd) {
      Ok((w, h)) => Size { width: w, height: h },
      Err(_) => Size { width: 80, height: 24 },
    }
  }

  /// Paint a whole frame. Homes the cursor (no full-screen erase), writes each
  /// line followed by erase-to-end-of-line so it overwrites the previous frame's
  /// residue in place, joins lines with CR+LF (raw mode gives no implicit CR),
  /// and finishes with erase-below so a frame shorter than the last leaves no
  /// stale rows. This is the standard flicker-free redraw; `view` guarantees the
  /// frame already fits the viewport, so nothing here can wrap.
  pub fn paint(self, frame: string) {
    write_raw(compose_frame(frame))
  }

  /// Leave raw mode and the alternate screen so an external program (the
  /// editor) owns a normal cooked terminal. Returns Ok on success; the caller
  /// pairs this with `resume`. Used only from the run loop's editor path.
  pub fn suspend(self) -> Result<(), error> {
    write_raw(f"{CURSOR_SHOW}{ALT_SCREEN_LEAVE}")
    term.Restore(self.fd, self.saved)?
    Ok(())
  }

  /// Re-enter raw mode and the alternate screen after `suspend`. The saved
  /// termios captured at `enter` is re-applied by making the fd raw again.
  pub fn resume(self: Ref<Terminal>) -> Result<(), error> {
    let saved = term.MakeRaw(self.fd)?
    self.saved = saved
    write_raw(f"{ALT_SCREEN_ENTER}{CURSOR_HIDE}{CLEAR_HOME}")
    Ok(())
  }
}

/// Build the raw byte stream for one flicker-free repaint of `frame`: home the
/// cursor, then each line + erase-to-EOL joined by CR+LF, then erase-below.
/// Pure and testable — the run loop's only side effect is `write_raw`ing this.
pub fn compose_frame(frame: string) -> string {
  let lines = strings.Split(frame, "\n")
  let cleared = lines.map(|line| f"{line}{ERASE_LINE}")
  let body = strings.Join(cleared, "\r\n")
  f"{CURSOR_HOME}{body}{ERASE_BELOW}"
}

/// Write a raw string straight to stdout. Errors are ignored: a terminal that
/// won't accept a frame is not something a redraw can recover from.
fn write_raw(s: string) {
  let _ = fmt.Fprint(os.Stdout, s)
}
