import "go:fmt"
import "go:time"
import "go:strings"
import "event"

/// Format a duration the way the Go list view does:
///   < 1ms  -> "123µs"
///   < 1s   -> "45.6ms"
///   else   -> "1.23s"
/// Ported from formatDurationValue.
pub fn duration(d: time.Duration) -> string {
  let micros = d.Microseconds()
  if d < time.Millisecond {
    fmt.Sprintf("%dµs", micros)
  } else if d < time.Second {
    let ms = (micros as float64) / 1000.0
    fmt.Sprintf("%.1fms", ms)
  } else {
    fmt.Sprintf("%.2fs", d.Seconds())
  }
}

/// HH:MM:SS.mmm in local time, matching the Go list column.
pub fn clock(t: time.Time) -> string {
  t.In(time.Local).Format("15:04:05.000")
}

/// HH:MM:SS in local time, matching the Go inspector's formatTimeFull.
pub fn clock_full(t: time.Time) -> string {
  t.In(time.Local).Format("15:04:05")
}

/// Collapse runs of whitespace, then truncate to `max_len` VISIBLE runes with
/// an ellipsis. Mirrors the Go `truncate` helper (rune-aware here). Measures
/// with `visible_len` so a styled input (highlighted SQL) truncates by what the
/// terminal shows, never by escape bytes.
pub fn truncate(s: string, max_len: int) -> string {
  let flat = collapse_ws(s)
  if visible_len(flat) <= max_len {
    return flat
  }
  if max_len <= 1 {
    return truncate_visible(flat, max_len)
  }
  truncate_visible(flat, max_len - 1) + "…"
}

// ESC (0x1b) as a rune, for skipping ANSI escape sequences when measuring
// visible width. Rune literals don't accept \x escapes; a const can't hold a
// cast; so compute it once via a helper. This is the single source of truth
// for the whole tui module (util.lis and view.lis call it).
fn esc_rune() -> rune {
  0x1b as rune
}

/// Count visible runes, skipping ANSI SGR escape sequences (ESC [ ... m). The
/// canonical width measure for the tui module — every fixed-width slot and
/// border computation goes through this, so styled strings measure by what the
/// terminal renders, not by their escape bytes.
pub fn visible_len(s: string) -> int {
  let esc = esc_rune()
  let mut n = 0
  let mut in_escape = false
  for r in s.runes() {
    if in_escape {
      if r == 'm' {
        in_escape = false
      }
    } else if r == esc {
      in_escape = true
    } else {
      n += 1
    }
  }
  n
}

/// Truncate `s` to `width` visible runes, preserving ANSI escapes and appending
/// a reset so a cut mid-color doesn't bleed.
pub fn truncate_visible(s: string, width: int) -> string {
  let esc = esc_rune()
  let mut out = ""
  let mut n = 0
  let mut in_escape = false
  let mut saw_escape = false
  for r in s.runes() {
    if n >= width {
      break
    }
    if in_escape {
      out += r as string
      if r == 'm' {
        in_escape = false
      }
    } else if r == esc {
      in_escape = true
      saw_escape = true
      out += r as string
    } else {
      out += r as string
      n += 1
    }
  }
  if saw_escape {
    out += SGR_RESET
  }
  out
}

fn collapse_ws(s: string) -> string {
  let trimmed = strings.TrimSpace(s)
  let mut out = ""
  let mut prev_space = false
  for r in trimmed.runes() {
    if r == ' ' || r == '\t' || r == '\n' || r == '\r' {
      if !prev_space {
        out += " "
      }
      prev_space = true
    } else {
      out += r as string
      prev_space = false
    }
  }
  out
}

/// Right-pad `s` to `width` VISIBLE cells with spaces. Measures with
/// `visible_len` (like Go's lipgloss.Width) so a styled label pads to the same
/// column a plain one would — mismatched padding here is what sheared borders.
pub fn pad_right(s: string, width: int) -> string {
  let w = visible_len(s)
  if w >= width {
    s
  } else {
    s + strings.Repeat(" ", width - w)
  }
}

/// Left-pad `s` to `width` VISIBLE cells with spaces.
pub fn pad_left(s: string, width: int) -> string {
  let w = visible_len(s)
  if w >= width {
    s
  } else {
    strings.Repeat(" ", width - w) + s
  }
}

/// The short op label shown in the Op column.
pub fn op_label(op: event.Op) -> string {
  match op {
    event.Op.Query => "Query",
    event.Op.Exec => "Exec",
    event.Op.Prepare => "Prepare",
    event.Op.Bind => "Bind",
    event.Op.Execute => "Execute",
    event.Op.Begin => "Begin",
    event.Op.Commit => "Commit",
    event.Op.Rollback => "Rollback",
  }
}

/// The status glyph for an event: E (error), N+1, SLOW, or blank.
pub fn status_label(ev: event.Event) -> string {
  if ev.outcome.is_failed() {
    "E"
  } else if ev.nplus1 {
    "N+1"
  } else if ev.slow {
    "SLOW"
  } else {
    ""
  }
}
