/// A decoded key event — the core's typed input vocabulary. Arrow/navigation
/// keys and control chords are named variants; everything printable rides
/// `Char(rune)`. `update` matches on this enum, so the whole state machine is
/// exercisable from constructed `Key` values with no terminal.
///
/// The byte decoder that used to live here is gone: Bubble Tea owns raw-mode
/// input now and hands us `tea.KeyMsg` values, which `tea_shim.decode_key`
/// maps into this enum by the same key strings Go switches on.
pub enum Key {
  Char(rune),
  Up,
  Down,
  Left,
  Right,
  PgUp,
  PgDown,
  Home,
  End,
  Enter,
  Backspace,
  Tab,
  Esc,
  Space,
  CtrlC,
  CtrlD,
  CtrlU,
  CtrlL,
}

/// The size of the terminal in character cells. Bubble Tea reports it via
/// `tea.WindowSizeMsg`, which the shim maps to `Msg.Resized`; `view` folds it
/// into the model so every renderer shares one source of truth.
pub struct Size {
  pub width: int,
  pub height: int,
}
